# ===========================================
# 2Care.ai Voice AI Agent Configuration
# ===========================================

# Application
APP_NAME=2Care.ai Voice Agent
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO

# Server
HOST=0.0.0.0
PORT=8000

# Database
DATABASE_URL=postgresql://care2ai:care2ai_secret@localhost:5432/care2ai_db
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# Redis
REDIS_URL=redis://localhost:6379/0
SESSION_TTL_SECONDS=1800

# OpenAI (STT & LLM)
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4-turbo-preview
OPENAI_WHISPER_MODEL=whisper-1

# Azure Speech Services (TTS for Indian languages)
AZURE_SPEECH_KEY=your-azure-speech-key
AZURE_SPEECH_REGION=eastus

# ElevenLabs (Optional - Natural English TTS)
ELEVENLABS_API_KEY=your-elevenlabs-key
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# Google Cloud (Fallback STT)
GOOGLE_APPLICATION_CREDENTIALS=/path/to/credentials.json

# Latency Targets (ms)
STT_LATENCY_TARGET=120
LLM_LATENCY_TARGET=200
TTS_LATENCY_TARGET=100
TOTAL_LATENCY_TARGET=450

# Voice Settings
VAD_SILENCE_THRESHOLD=0.5
VAD_MIN_SPEECH_DURATION=0.25
AUDIO_SAMPLE_RATE=16000
AUDIO_CHANNELS=1

# Security
JWT_SECRET_KEY=your-super-secret-jwt-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Twilio (Phone Integration)
TWILIO_ACCOUNT_SID=your-twilio-sid
TWILIO_AUTH_TOKEN=your-twilio-token
TWILIO_PHONE_NUMBER=+1234567890

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]
